# Production Environment Configuration for FELScanner v2

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_DB=felscanner
POSTGRES_USER=felscanner
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ==========================================
# Redis Configuration
# ==========================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# ==========================================
# Plex Configuration
# ==========================================
PLEX_URL=http://your-plex-server:32400
PLEX_TOKEN=YOUR_PLEX_TOKEN_HERE
PLEX_LIBRARY_NAME=Movies
PLEX_MEDIA_PATH=/path/to/your/plex/media

# ==========================================
# Plex Collections
# ==========================================
COLLECTION_DV_P7=Dolby Vision - Profile 7
COLLECTION_DV_FEL=Dolby Vision - FEL
COLLECTION_ATMOS=Dolby Atmos

# ==========================================
# qBittorrent Configuration
# ==========================================
QBITTORRENT_URL=http://your-qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=YOUR_QBIT_PASSWORD

# ==========================================
# Radarr Configuration
# ==========================================
RADARR_URL=http://your-radarr:7878
RADARR_API_KEY=YOUR_RADARR_API_KEY

# ==========================================
# Telegram Configuration
# ==========================================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ==========================================
# IPTorrents Configuration
# ==========================================
IPT_ENABLED=true
IPT_URL=https://www.iptorrents.com
IPT_UID=YOUR_IPT_UID
IPT_PASS=YOUR_IPT_PASS

# ==========================================
# Service URLs (Internal Docker Network)
# ==========================================
IPT_SCRAPER_URL=http://ipt-scraper:3000
FLARESOLVERR_URL=http://flaresolverr:8191

# ==========================================
# Application Settings
# ==========================================
AUTO_START_MODE=disabled
LOG_LEVEL=INFO
FLARESOLVERR_LOG_LEVEL=info

# ==========================================
# Port Mappings (Host)
# ==========================================
API_PORT=8000
FRONTEND_PORT=5173
IPT_SCRAPER_PORT=3000
FLARESOLVERR_PORT=8191

# ==========================================
# Frontend Build Configuration
# ==========================================
VITE_API_BASE_URL=/api
