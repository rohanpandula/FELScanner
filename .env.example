# FELScanner v2 Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=FELScanner
DEBUG=false
LOG_LEVEL=INFO
TZ=America/New_York

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_DB=felscanner
POSTGRES_USER=felscanner
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=
REDIS_PORT=6379

# ============================================================================
# API SERVICE
# ============================================================================
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ============================================================================
# PLEX
# Required: Get token from https://www.plex.tv/claim or Plex settings
# ============================================================================
PLEX_URL=http://your-plex-server:32400
PLEX_TOKEN=YOUR_PLEX_TOKEN_HERE
LIBRARY_NAME=Movies

# ============================================================================
# FFPROBE
# Path to ffprobe binary (auto-detected if in PATH)
# ============================================================================
FFPROBE_PATH=/usr/bin/ffprobe

# ============================================================================
# TELEGRAM
# Get bot token from @BotFather
# Get chat ID from @userinfobot
# ============================================================================
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ============================================================================
# QBITTORRENT
# ============================================================================
QBITTORRENT_HOST=
QBITTORRENT_PORT=8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
QBITTORRENT_CATEGORY=movies-fel

# ============================================================================
# RADARR
# ============================================================================
RADARR_URL=
RADARR_API_KEY=
RADARR_ROOT_PATH=

# ============================================================================
# IPTORRENTS
# Get cookies from browser after logging into IPTorrents
# ============================================================================
IPT_UID=
IPT_PASS=
IPT_SEARCH_TERM=BL+EL+RPU
IPT_HEADLESS=true

# ============================================================================
# FLARESOLVERR
# ============================================================================
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_PORT=8191

# ============================================================================
# IPT SCRAPER SERVICE
# ============================================================================
IPT_SCRAPER_URL=http://ipt-scraper:3000
IPT_SCRAPER_PORT=3000

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# BACKGROUND TASKS
# ============================================================================
SCAN_FREQUENCY_HOURS=24
MONITOR_INTERVAL_MINUTES=1
CONNECTION_CHECK_INTERVAL_MINUTES=15

# ============================================================================
# MONITORING
# ============================================================================
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# ============================================================================
# NGINX (Optional - for production)
# ============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FRONTEND_NGINX_HOST=localhost
FRONTEND_NGINX_PORT=80
